        <li>Priority email support</li>
        <li>Bonus: Founder's Quick Start Guide (PDF)</li>
      </ul>
      <a href="/checkout.html?product=notion-pro&price=29" class="btn btn-warm">Get Pro Bundle — $29</a>
    </div>
  </div>
</section>

<!-- TESTIMONIALS -->
<div class="divider"></div>
<section class="section">
  <div class="section-header">
    <h2>What Founders Say</h2>
  </div>
  <div class="testimonials-grid">

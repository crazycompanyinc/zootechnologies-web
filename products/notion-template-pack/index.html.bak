</section>

<!-- PROBLEM -->
<div class="divider"></div>
<section class="section">
  <div class="section-header">
    <h2>Sound Familiar?</h2>
    <p>You should be shipping code, not tweaking databases.</p>
  </div>
  <div class="problem-grid">
    <div class="problem-card">
      <div class="icon">🔍</div>
      <p>Googling "best Notion templates for startups" for the 5th time</p>
    </div>
    <div class="problem-card">
      <div class="icon">📺</div>
      <p>Watching YouTube tutorials on how to build a CRM in Notion</p>
    </div>
    <div class="problem-card">
      <div class="icon">📋</div>
      <p>Copy-pasting from 5 different template galleries</p>
    </div>
    <div class="problem-card">
      <div class="icon">😵</div>
      <p>Still ending up with a mess that doesn't work</p>
    </div>
  </div>
</section>

<!-- TEMPLATES BENTO -->
<div class="divider"></div>
<section class="section" id="templates">
  <div class="section-header">
    <h2>What's Inside</h2>
    <p>10 plug-and-play templates. Duplicate. Customize. Done.</p>
  </div>
  <div class="bento">
    <div class="bento-item bento-span-2">
      <div class="emoji">🏢</div>
      <h3>Startup OS</h3>
      <p>Complete company wiki with team directory, meeting notes, decision logs, and company handbook template.</p>
      <span class="tag tag-free">STARTER</span>
    </div>
    <div class="bento-item bento-span-2">
      <div class="emoji">🗺️</div>
      <h3>Product Roadmap</h3>
      <p>Feature prioritization matrix, sprint planning board, release checklist, and changelog template.</p>
      <span class="tag tag-free">STARTER</span>
    </div>
    <div class="bento-item bento-span-2">
      <div class="emoji">🤝</div>
      <h3>Customer CRM</h3>
      <p>Lead pipeline, contact tracker, follow-up reminders, and deal stages. Never lose a hot lead.</p>
      <span class="tag tag-free">STARTER</span>
    </div>
    <div class="bento-item bento-span-2">
      <div class="emoji">📅</div>
      <h3>Content Calendar</h3>
      <p>Blog planner, social media scheduler, publishing checklist, and analytics dashboard.</p>
      <span class="tag tag-free">STARTER</span>
    </div>
    <div class="bento-item bento-span-2">
      <div class="emoji">💰</div>
      <h3>Finance Tracker</h3>
      <p>Burn rate calculator, runway tracker, revenue dashboard, and expense log.</p>
      <span class="tag tag-free">STARTER</span>
    </div>
    <div class="bento-item">
      <div class="emoji">💵</div>
      <h3>Fundraising Tracker</h3>
      <p>Investor CRM, pitch deck version control, term sheet comparison.</p>
      <span class="tag tag-pro">PRO</span>
    </div>
    <div class="bento-item">
      <div class="emoji">👥</div>
      <h3>Hiring Pipeline</h3>
      <p>Job postings, candidate tracker, interview scorecards, offer letters.</p>
      <span class="tag tag-pro">PRO</span>
    </div>
    <div class="bento-item">
      <div class="emoji">🎯</div>
      <h3>OKR Dashboard</h3>
      <p>Quarterly goals framework, key results tracker, weekly check-ins.</p>
      <span class="tag tag-pro">PRO</span>
    </div>
    <div class="bento-item">
      <div class="emoji">📋</div>
      <h3>Sprint Board</h3>
      <p>Kanban with velocity tracking, bug tracker, retrospective templates.</p>
      <span class="tag tag-pro">PRO</span>
    </div>
    <div class="bento-item">
      <div class="emoji">📓</div>
      <h3>Founder Journal</h3>
      <p>Daily standup, weekly review, monthly reflection, gratitude journal.</p>
      <span class="tag tag-pro">PRO</span>
    </div>
  </div>
</section>

<!-- PRICING -->
<div class="divider"></div>
<section class="section" id="pricing">
  <div class="section-header">
    <h2>Simple Pricing</h2>
    <p>One-time purchase. Free updates forever.</p>
  </div>
  <div class="pricing-grid">
    <div class="pricing-card">
      <h3>Starter Pack</h3>
      <div class="price">
        <span class="currency">$</span><span class="amount">19</span>

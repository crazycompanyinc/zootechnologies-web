<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Agent Starter Kit — Build Production AI Agents in Minutes | ZOO</title>
<meta name="description" content="Production-ready AI Agent boilerplate with memory, tool calling, multi-agent orchestration, and governance. Python + TypeScript. $49.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0a0b;
  --surface: #12121a;
  --surface2: #1a1a26;
  --border: #2a2a3a;
  --border-hover: #3a3a4e;
  --text: #e8e8f0;
  --text2: #8888a0;
  --text3: #55556a;
  --accent: #6366f1;
  --accent2: #818cf8;
  --accent-glow: rgba(99,102,241,0.3);
  --warm: #ff6b35;
  --warm-glow: rgba(255,107,53,0.3);
  --green: #22c55e;
  --cyan: #06b6d4;
  --gradient: linear-gradient(135deg, #6366f1, #a855f7, #ec4899);
  --font-body: 'Inter', -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
  --ease: cubic-bezier(0.16, 1, 0.3, 1);
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* NAV */
.nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 100;
  background: rgba(10,10,11,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  height: 64px;
  display: flex; align-items: center;
}
.nav-inner {
  max-width: 1100px; margin: 0 auto; padding: 0 24px;
  width: 100%;
  display: flex; align-items: center; justify-content: space-between;
}
.nav-logo {
  font-weight: 800; font-size: 18px;
  background: var(--gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  text-decoration: none;
}
.nav-cta {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 20px;
  background: var(--accent);
  color: #fff;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 600;
  font-size: 14px;
  transition: all 0.3s var(--ease);
  box-shadow: 0 2px 12px var(--accent-glow);
}
.nav-cta:hover { background: var(--accent2); transform: translateY(-1px); }

/* HERO */
.hero {
  padding: 140px 24px 80px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hero-glow {
  position: absolute; top: -120px; left: 50%; transform: translateX(-50%);
  width: 700px; height: 500px;
  background: radial-gradient(ellipse, rgba(99,102,241,0.15) 0%, transparent 70%);
  pointer-events: none;
}
.hero-content { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; }
.hero-badge {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 6px 16px; border-radius: 999px;
  font-size: 12px; font-weight: 600;
  background: rgba(99,102,241,0.1); color: var(--accent2);
  border: 1px solid rgba(99,102,241,0.2);
  margin-bottom: 24px;
}
.hero h1 {
  font-size: clamp(36px, 6vw, 56px);
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: -0.03em;
  margin-bottom: 20px;
}
.hero h1 .highlight {
  background: var(--gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
.hero p {
  color: var(--text2);
  font-size: clamp(16px, 2vw, 20px);
  max-width: 580px;
  margin: 0 auto 36px;
  line-height: 1.65;
}
.hero-actions {
  display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;
}
.code-showcase {
  max-width: 600px;
  margin: 48px auto 0;
  text-align: left;
}
.code-showcase pre {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 20px 24px;
  font-family: var(--font-mono);
  font-size: 13px;
  line-height: 1.8;
  overflow-x: auto;
}
.code-showcase .keyword { color: var(--accent2); }
.code-showcase .string { color: var(--green); }
.code-showcase .func { color: var(--cyan); }
.code-showcase .comment { color: var(--text3); }

/* BUTTONS */
.btn {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 16px 32px; border-radius: 12px;
  font-weight: 700; font-size: 16px;
  text-decoration: none; border: none; cursor: pointer;
  transition: all 0.3s var(--ease);
  font-family: var(--font-body);
}
.btn-primary {
  background: var(--gradient);
  color: #fff;
  box-shadow: 0 4px 24px var(--accent-glow);
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 40px var(--accent-glow);
}
.btn-ghost {
  background: transparent; color: var(--text);
  border: 1px solid var(--border);
}
.btn-ghost:hover { background: rgba(255,255,255,0.04); border-color: var(--border-hover); }

/* SECTIONS */
.section {
  padding: 80px 24px;
  max-width: 1100px;
  margin: 0 auto;
}
.section-header {
  text-align: center;
  margin-bottom: 48px;
}
.section-header h2 {
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 800;
  letter-spacing: -0.02em;
  margin-bottom: 12px;
}
.section-header p {
  color: var(--text2);
  font-size: 17px;
  max-width: 520px;
  margin: 0 auto;
}

/* MODULES GRID */
.modules-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 16px;
}
.module-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 28px;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}
.module-card:hover {
  border-color: var(--accent);
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(99,102,241,0.12);
}
.module-number {
  font-family: var(--font-mono);
  font-size: 11px;
  font-weight: 600;
  color: var(--accent2);
  background: rgba(99,102,241,0.1);
  padding: 4px 10px;
  border-radius: 6px;
  display: inline-block;
  margin-bottom: 14px;
}
.module-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 8px; }
.module-card p { color: var(--text2); font-size: 14px; line-height: 1.6; }
.module-card .stack {
  margin-top: 12px;
  display: flex; gap: 6px; flex-wrap: wrap;
}
.module-card .stack span {
  font-family: var(--font-mono);
  font-size: 10px;
  padding: 3px 8px;
  border-radius: 4px;
  background: rgba(255,255,255,0.04);
  color: var(--text3);
  border: 1px solid var(--border);
}

/* TECH STACK */
.stack-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
}
.stack-item {
  padding: 10px 20px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  font-size: 14px;
  font-weight: 500;
  color: var(--text2);
}

/* PRICING */
.pricing-card {
  max-width: 520px;
  margin: 0 auto;
  background: var(--surface);
  border: 2px solid var(--accent);
  border-radius: 24px;
  padding: 48px;
  text-align: center;
  position: relative;
  box-shadow: 0 0 60px rgba(99,102,241,0.15);
}
.pricing-badge {
  position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
  background: var(--gradient);
  color: #fff;
  padding: 6px 24px;
  border-radius: 999px;
  font-size: 12px; font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  white-space: nowrap;
}
.pricing-card h3 { font-size: 24px; font-weight: 800; margin-top: 8px; }
.pricing-amount { margin: 20px 0; }
.pricing-amount .currency { font-size: 28px; vertical-align: super; }
.pricing-amount .value { font-size: 64px; font-weight: 800; letter-spacing: -0.04em; }
.pricing-amount .period { color: var(--text2); font-size: 14px; }
.pricing-features { list-style: none; margin: 24px 0; text-align: left; }
.pricing-features li {
  padding: 10px 0;
  font-size: 15px;
  color: var(--text2);
  display: flex; align-items: center; gap: 12px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.pricing-features li::before {
  content: '✓';
  color: var(--green);
  font-weight: 700;
  font-size: 14px;
  flex-shrink: 0;
}
.pricing-card .btn { width: 100%; justify-content: center; padding: 18px; font-size: 17px; }
.pricing-guarantee {
  margin-top: 14px;
  color: var(--text3);
  font-size: 13px;
}

/* WHATYOUBUILD */
.build-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 14px;
}
.build-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 24px;
  text-align: center;
}
.build-card .icon { font-size: 32px; margin-bottom: 10px; }
.build-card h4 { font-size: 15px; font-weight: 600; }
.build-card p { color: var(--text2); font-size: 13px; margin-top: 4px; }
.build-card .soon {
  display: inline-block;
  margin-top: 8px;
  padding: 3px 10px;
  border-radius: 6px;
  font-size: 11px; font-weight: 600;
  background: rgba(99,102,241,0.1);
  color: var(--accent2);
  border: 1px solid rgba(99,102,241,0.2);
}

/* FAQ */
.faq-grid {
  max-width: 680px;
  margin: 0 auto;
  display: grid;
  gap: 12px;
}
.faq-item {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 24px;
}
.faq-item h4 { font-size: 15px; font-weight: 600; margin-bottom: 6px; }
.faq-item p { color: var(--text2); font-size: 14px; line-height: 1.6; }

/* CTA */
.cta-final {
  text-align: center;
  padding: 64px 32px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 24px;
  margin: 0 24px 80px;
  max-width: 1100px;
  margin-left: auto;
  margin-right: auto;
  position: relative;
  overflow: hidden;
}
.cta-final::before {
  content: '';
  position: absolute;
  top: -50%; left: -50%;
  width: 200%; height: 200%;
  background: radial-gradient(ellipse at center, rgba(99,102,241,0.1) 0%, transparent 60%);
  pointer-events: none;
}
.cta-final h2 {
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 800;
  margin-bottom: 12px;
  position: relative;
}
.cta-final p {
  color: var(--text2);
  font-size: 17px;
  margin-bottom: 28px;
  position: relative;
}
.cta-final .btn { position: relative; }

/* FOOTER */
.footer {
  text-align: center;
  padding: 48px 24px;
  color: var(--text2);
  font-size: 13px;
  border-top: 1px solid var(--border);
}

/* DIVIDER */
.divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border), transparent);
  margin: 0 auto;
  max-width: 1100px;
}

@media (max-width: 768px) {
  .hero { padding: 120px 20px 60px; }
  .section { padding: 60px 20px; }
  .pricing-card { padding: 32px 24px; }
  .modules-grid { grid-template-columns: 1fr; }
}
</style>
</head>

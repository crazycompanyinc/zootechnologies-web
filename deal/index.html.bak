<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0a0a0f;--card:#111118;--border:#1e1e2e;--accent:#7c3aed;--accent2:#a855f7;--green:#10b981;--red:#ef4444;--text:#e2e8f0;--muted:#94a3b8}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;background:var(--bg);color:var(--text);line-height:1.6;overflow-x:hidden}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes countdown{pulse 1s infinite}
@keyframes slideIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes glow{0%,100%{box-shadow:0 0 20px rgba(124,58,237,.3)}50%{box-shadow:0 0 40px rgba(124,58,237,.6)}}
.container{max-width:900px;margin:0 auto;padding:0 20px}
.nav{padding:20px 0;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.nav-logo{font-size:1.4rem;font-weight:800;background:linear-gradient(135deg,var(--accent),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.nav-badge{background:var(--red);color:#fff;padding:4px 12px;border-radius:20px;font-size:.75rem;font-weight:700;animation:pulse 2s infinite}
.hero{padding:60px 0 40px;text-align:center;position:relative}
.hero::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:600px;height:600px;background:radial-gradient(circle,rgba(124,58,237,.15) 0%,transparent 70%);z-index:-1}
.urgency-bar{background:linear-gradient(90deg,var(--red),#f97316);color:#fff;padding:10px 20px;border-radius:8px;font-weight:700;font-size:.9rem;margin-bottom:30px;display:inline-block;animation:pulse 1.5s infinite}
.hero h1{font-size:clamp(2rem,5vw,3.2rem);font-weight:900;line-height:1.1;margin-bottom:20px;background:linear-gradient(135deg,#fff,var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero h1 span{color:var(--green);-webkit-text-fill-color:var(--green)}
.hero-sub{font-size:1.2rem;color:var(--muted);max-width:600px;margin:0 auto 30px}
.price-box{display:flex;align-items:center;justify-content:center;gap:20px;margin:30px 0}
.price-old{font-size:2rem;color:var(--muted);text-decoration:line-through}
.price-new{font-size:3.5rem;font-weight:900;color:var(--green)}
.price-save{background:var(--green);color:#fff;padding:4px 12px;border-radius:20px;font-size:.85rem;font-weight:700}
.cta-btn{display:inline-block;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;padding:18px 48px;border-radius:12px;font-size:1.2rem;font-weight:800;text-decoration:none;transition:all .3s;animation:glow 2s infinite;border:none;cursor:pointer}
.cta-btn:hover{transform:scale(1.05);box-shadow:0 0 60px rgba(124,58,237,.5)}
.cta-sub{margin-top:12px;font-size:.85rem;color:var(--muted)}
.countdown{display:flex;gap:15px;justify-content:center;margin:30px 0}
.countdown-item{background:var(--card);border:1px solid var(--border);padding:15px 20px;border-radius:12px;text-align:center;min-width:80px}
.countdown-num{font-size:2rem;font-weight:900;color:var(--accent2)}
.countdown-label{font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:1px}
.trust-badges{display:flex;gap:20px;justify-content:center;flex-wrap:wrap;margin:30px 0}
.trust-badge{background:var(--card);border:1px solid var(--border);padding:8px 16px;border-radius:8px;font-size:.8rem;color:var(--muted)}
.section{padding:50px 0}
.section h2{font-size:1.8rem;font-weight:800;margin-bottom:30px;text-align:center}
.features{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px}
.feature{background:var(--card);border:1px solid var(--border);padding:24px;border-radius:12px;transition:transform .3s}
.feature:hover{transform:translateY(-4px);border-color:var(--accent)}
.feature-icon{font-size:2rem;margin-bottom:12px}
.feature h3{font-size:1.1rem;font-weight:700;margin-bottom:8px}
.feature p{font-size:.9rem;color:var(--muted)}
.included{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:30px;margin:30px 0}
.included h3{font-size:1.3rem;font-weight:700;margin-bottom:20px;text-align:center}
.included-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px}
.included-item{display:flex;align-items:center;gap:10px;padding:8px 0}
.included-check{color:var(--green);font-weight:700}
.testimonial{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:24px;margin:20px 0;font-style:italic;color:var(--muted)}
.testimonial-author{margin-top:12px;font-style:normal;font-weight:700;color:var(--text);font-size:.9rem}
.faq-item{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;margin:12px 0}
.faq-q{font-weight:700;margin-bottom:8px;cursor:pointer}
.faq-a{color:var(--muted);font-size:.9rem}
.final-cta{padding:60px 0;text-align:center;background:linear-gradient(180deg,transparent,rgba(124,58,237,.05))}
.final-cta h2{font-size:2rem;font-weight:900;margin-bottom:15px}
.final-cta p{color:var(--muted);margin-bottom:30px;font-size:1.1rem}
.guarantee{display:flex;align-items:center;justify-content:center;gap:10px;margin-top:20px;color:var(--green);font-size:.9rem;font-weight:600}
.footer{padding:30px 0;border-top:1px solid var(--border);text-align:center;color:var(--muted);font-size:.8rem}
@media(max-width:600px){.price-box{flex-direction:column;gap:10px}.countdown{gap:8px}.countdown-item{min-width:60px;padding:10px}}
</style>
</head>
<body>


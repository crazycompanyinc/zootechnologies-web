<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ZOO vs Carrd vs Typedream vs Dorik — Landing Page Templates | 90% Cheaper</title>
<meta name="description" content="Stop paying $468-1,200/year for landing page builders. ZOO templates: $29 once. Compare pricing, features, and why owning beats renting.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --zoo: #6C3AED;
  --zoo-light: #8B5CF6;
  --zoo-dark: #5B21B6;
  --green: #10B981;
  --red: #EF4444;
  --bg: #0A0A0F;
  --card: #141420;
  --card-hover: #1a1a2e;
  --border: #2a2a3e;
  --text: #e2e8f0;
  --text-dim: #94a3b8;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; }
.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

/* Nav */
.nav { padding: 20px 0; border-bottom: 1px solid var(--border); }
.nav-inner { display: flex; align-items: center; justify-content: space-between; }
.logo { font-size: 24px; font-weight: 900; color: white; text-decoration: none; }
.logo span { color: var(--zoo-light); }
.nav-cta { background: var(--zoo); color: white; padding: 10px 24px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 14px; }
.nav-cta:hover { background: var(--zoo-light); }

/* Hero */
.hero { padding: 80px 0 60px; text-align: center; }
.hero-badge { display: inline-block; background: rgba(108,58,237,0.15); border: 1px solid rgba(108,58,237,0.3); color: var(--zoo-light); padding: 8px 20px; border-radius: 50px; font-size: 14px; font-weight: 600; margin-bottom: 24px; }
.hero h1 { font-size: 56px; font-weight: 900; line-height: 1.1; margin-bottom: 24px; background: linear-gradient(135deg, #fff 0%, #a78bfa 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.hero h1 .highlight { color: var(--green); -webkit-text-fill-color: var(--green); }
.hero-sub { font-size: 20px; color: var(--text-dim); max-width: 640px; margin: 0 auto 40px; }
.hero-cta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.btn-primary { background: linear-gradient(135deg, var(--zoo), var(--zoo-light)); color: white; padding: 16px 40px; border-radius: 12px; text-decoration: none; font-weight: 700; font-size: 18px; display: inline-block; }
.btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(108,58,237,0.4); }
.btn-secondary { background: var(--card); color: white; padding: 16px 40px; border-radius: 12px; text-decoration: none; font-weight: 600; font-size: 18px; border: 1px solid var(--border); }

/* Comparison Table */
.compare { padding: 60px 0; }
.compare h2 { text-align: center; font-size: 36px; font-weight: 800; margin-bottom: 12px; }
.compare-sub { text-align: center; color: var(--text-dim); font-size: 18px; margin-bottom: 48px; }
.table-wrap { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; background: var(--card); border-radius: 16px; overflow: hidden; }
th { padding: 20px 24px; text-align: left; font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid var(--border); }
th:first-child { background: var(--card); }
th.zoo-col { background: rgba(108,58,237,0.2); color: var(--zoo-light); }
td { padding: 18px 24px; border-bottom: 1px solid var(--border); font-size: 15px; }
td:first-child { font-weight: 600; color: var(--text-dim); }
td.zoo-col { background: rgba(108,58,237,0.08); font-weight: 700; color: var(--green); }
tr:last-child td { border-bottom: none; }
tr:hover td { background: rgba(255,255,255,0.02); }
.price-wrong { color: var(--red); text-decoration: line-through; opacity: 0.7; }
.price-right { color: var(--green); font-weight: 800; font-size: 18px; }
.check { color: var(--green); font-weight: 700; }
.cross { color: var(--red); opacity: 0.6; }
.winner-row { background: rgba(108,58,237,0.05); }
.winner-badge { display: inline-block; background: var(--zoo); color: white; padding: 2px 10px; border-radius: 4px; font-size: 11px; font-weight: 700; margin-left: 8px; text-transform: uppercase; }

/* Savings Calculator */
.savings { padding: 60px 0; }
.savings-card { background: linear-gradient(135deg, rgba(108,58,237,0.1), rgba(16,185,129,0.1)); border: 1px solid var(--border); border-radius: 20px; padding: 48px; text-align: center; }
.savings-card h2 { font-size: 36px; font-weight: 800; margin-bottom: 16px; }
.savings-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 24px; margin-top: 40px; }
.saving-item { background: var(--card); border-radius: 12px; padding: 24px; border: 1px solid var(--border); }
.saving-item .competitor-name { font-size: 14px; color: var(--text-dim); margin-bottom: 8px; }
.saving-item .their-price { font-size: 24px; font-weight: 700; color: var(--red); text-decoration: line-through; }
.saving-item .our-price { font-size: 28px; font-weight: 900; color: var(--green); }
.saving-item .save-label { font-size: 13px; color: var(--green); font-weight: 600; margin-top: 4px; }

/* Pain Points */
.pain { padding: 60px 0; }
.pain h2 { text-align: center; font-size: 36px; font-weight: 800; margin-bottom: 48px; }
.pain-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(340px, 1fr)); gap: 24px; }
.pain-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 32px; }
.pain-card h3 { font-size: 20px; font-weight: 700; margin-bottom: 12px; display: flex; align-items: center; gap: 12px; }
.pain-card .icon { font-size: 28px; }
.pain-card p { color: var(--text-dim); font-size: 15px; line-height: 1.7; }
.pain-card .solution { margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border); color: var(--green); font-weight: 600; font-size: 14px; }

/* Features */
.features { padding: 60px 0; }
.features h2 { text-align: center; font-size: 36px; font-weight: 800; margin-bottom: 48px; }
.feat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
.feat-card { background: var(--card); border: 1px solid var(--border); border-radius: 16px; padding: 32px; text-align: center; }
.feat-card .icon { font-size: 48px; margin-bottom: 16px; }
.feat-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
.feat-card p { color: var(--text-dim); font-size: 14px; }

/* CTA */
.cta-section { padding: 80px 0; text-align: center; }
.cta-box { background: linear-gradient(135deg, var(--zoo-dark), #1e1b4b); border-radius: 24px; padding: 64px 48px; border: 1px solid rgba(108,58,237,0.3); }
.cta-box h2 { font-size: 42px; font-weight: 900; margin-bottom: 16px; }
.cta-box p { color: var(--text-dim); font-size: 18px; margin-bottom: 32px; max-width: 560px; margin-left: auto; margin-right: auto; }
.cta-price { font-size: 56px; font-weight: 900; color: white; margin: 24px 0; }
.cta-price span { font-size: 20px; color: var(--text-dim); text-decoration: line-through; margin-right: 12px; }

/* Footer */
footer { padding: 40px 0; border-top: 1px solid var(--border); text-align: center; color: var(--text-dim); font-size: 14px; }

@media (max-width: 768px) {
  .hero h1 { font-size: 36px; }
  .hero-sub { font-size: 16px; }
  .cta-box h2 { font-size: 28px; }
  .cta-price { font-size: 40px; }
  th, td { padding: 12px 16px; font-size: 13px; }
}
</style>
</head>

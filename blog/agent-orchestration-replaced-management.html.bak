<style>
:root{--black:#060608;--dark:#0b0b0d;--surface:#121214;--border:rgba(255,255,255,0.06);--border-light:rgba(255,255,255,0.1);--text:#e8e6e3;--text-dim:#6a6a6a;--text-muted:#3a3a3a;--accent:#c9a96e;--accent-glow:rgba(201,169,110,0.15);--green:#22c55e;--font-serif:'Playfair Display',Georgia,serif;--font-sans:'Inter',-apple-system,sans-serif;--font-mono:'JetBrains Mono',monospace;--ease:cubic-bezier(0.16,1,0.3,1)}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{background:var(--black);-webkit-font-smoothing:antialiased}
body{font-family:var(--font-sans);background:var(--black);color:var(--text);line-height:1.7}

.nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:24px 48px;display:flex;justify-content:space-between;align-items:center;transition:all 0.6s var(--ease)}
.nav.scrolled{padding:14px 48px;background:rgba(6,6,8,0.95);backdrop-filter:blur(40px);border-bottom:1px solid var(--border)}

.article-meta{display:flex;align-items:center;gap:20px;margin-bottom:40px;font-size:0.8rem;color:var(--text-dim)}
.article-meta span{display:flex;align-items:center;gap:6px}
.article-hero-img{width:100%;height:360px;object-fit:cover;border-radius:16px;filter:grayscale(30%) contrast(1.05);margin-bottom:48px}
.article-body{max-width:700px;margin:0 auto;padding:0 48px 120px}
.article-body h2{font-family:var(--font-serif);font-size:1.6rem;font-weight:700;margin:48px 0 16px;line-height:1.3}

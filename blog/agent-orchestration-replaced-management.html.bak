.article-body li::marker{color:var(--accent)}
pre{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px;margin:24px 0;overflow-x:auto;font-family:var(--font-mono);font-size:0.82rem;line-height:1.7;color:var(--text)}
code{font-family:var(--font-mono);background:var(--surface);padding:2px 6px;border-radius:4px;font-size:0.85em;color:var(--accent)}
pre code{background:none;padding:0;color:var(--text)}
blockquote{border-left:3px solid var(--accent);padding:16px 24px;margin:32px 0;background:var(--accent-glow);border-radius:0 8px 8px 0;font-style:italic;color:var(--text)}
.cta-box{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:36px;margin:48px 0;text-align:center}
.cta-box h3{font-family:var(--font-serif);font-size:1.4rem;font-weight:700;margin-bottom:12px}
.cta-box p{color:var(--text-dim);font-size:0.9rem;margin-bottom:24px}
.cta-box .btn{display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:var(--accent);color:#000;border-radius:10px;font-weight:600;font-size:0.85rem;text-decoration:none;transition:all 0.3s;font-family:var(--font-sans)}
.cta-box .btn:hover{background:#dbc08a;transform:translateY(-1px)}
.footer{padding:48px;border-top:1px solid var(--border);text-align:center}
.footer p{color:var(--text-muted);font-size:0.78rem}
.footer a{color:var(--accent);text-decoration:none}

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ZOO vs Dify vs Cursor — AI Agent Tools Compared | Own It Once vs $59-240/mo</title>
<meta name="description" content="Dify charges $59-159/mo per workspace. Cursor charges $20-200/mo. ZOO AI Agent Kit: $49 once. Compare features, pricing, and why one-time purchase beats monthly SaaS for AI agent development.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --zoo: #6C3AED;
  --zoo-light: #8B5CF6;
  --zoo-dark: #5B21B6;
  --green: #10B981;
  --red: #EF4444;
  --bg: #0A0A0F;
  --card: #141420;
  --card-hover: #1a1a2e;
  --border: #2a2a3e;
  --text: #e2e8f0;
  --text-dim: #94a3b8;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; }
.container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

/* Nav */
.nav { padding: 20px 0; border-bottom: 1px solid var(--border); }
.nav-inner { display: flex; align-items: center; justify-content: space-between; }
.logo { font-weight: 900; font-size: 1.4rem; color: var(--zoo-light); text-decoration: none; }
.nav-cta { background: var(--zoo); color: #fff; padding: 10px 24px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 0.9rem; }
.nav-cta:hover { background: var(--zoo-light); }

/* Hero */
.hero { padding: 80px 0 60px; text-align: center; }
.hero-badge { display: inline-block; background: rgba(108,58,237,0.15); border: 1px solid var(--zoo); color: var(--zoo-light); padding: 6px 16px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; margin-bottom: 24px; }
.hero h1 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 900; line-height: 1.15; margin-bottom: 20px; }
.hero h1 .highlight { color: var(--zoo-light); }
.hero p { font-size: 1.15rem; color: var(--text-dim); max-width: 640px; margin: 0 auto 32px; }
.hero-cta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
.btn-primary { background: var(--zoo); color: #fff; padding: 14px 36px; border-radius: 10px; text-decoration: none; font-weight: 700; font-size: 1.05rem; }
.btn-primary:hover { background: var(--zoo-light); }
.btn-secondary { background: transparent; color: var(--text); border: 1px solid var(--border); padding: 14px 36px; border-radius: 10px; text-decoration: none; font-weight: 600; font-size: 1.05rem; }

/* Pain Section */
.pain { padding: 60px 0; }
.pain h2 { text-align: center; font-size: 1.8rem; font-weight: 800; margin-bottom: 40px; }
.pain-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
.pain-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 28px; }
.pain-card .icon { font-size: 2rem; margin-bottom: 12px; }
.pain-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; }
.pain-card p { color: var(--text-dim); font-size: 0.95rem; }
.pain-card .price-tag { display: inline-block; background: rgba(239,68,68,0.15); color: var(--red); padding: 3px 10px; border-radius: 6px; font-weight: 700; font-size: 0.85rem; margin-top: 10px; }

/* Comparison Table */
.compare { padding: 60px 0; }
.compare h2 { text-align: center; font-size: 1.8rem; font-weight: 800; margin-bottom: 12px; }
.compare-sub { text-align: center; color: var(--text-dim); margin-bottom: 40px; }
.table-wrap { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; min-width: 700px; }
th { padding: 16px 20px; text-align: left; font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 2px solid var(--border); }
th.zoo-col { background: rgba(108,58,237,0.1); color: var(--zoo-light); }
td { padding: 14px 20px; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
tr:hover td { background: rgba(255,255,255,0.02); }
.zoo-row { background: rgba(108,58,237,0.05); }
.check { color: var(--green); font-weight: 700; }
.cross { color: var(--red); opacity: 0.6; }
.price-zoo { color: var(--green); font-weight: 800; font-size: 1.1rem; }
.price-bad { color: var(--red); font-weight: 600; }

/* Savings Calculator */
.savings { padding: 60px 0; }
.savings h2 { text-align: center; font-size: 1.8rem; font-weight: 800; margin-bottom: 40px; }
.savings-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; max-width: 900px; margin: 0 auto; }
.saving-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 28px; text-align: center; }
.saving-card .vs-label { font-size: 0.8rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
.saving-card .competitor-name { font-weight: 700; font-size: 1.1rem; margin-bottom: 4px; }
.saving-card .their-price { color: var(--red); font-size: 1.4rem; font-weight: 800; }
.saving-card .our-price { color: var(--green); font-size: 1.4rem; font-weight: 800; margin: 8px 0; }
.saving-card .save-amount { background: rgba(16,185,129,0.15); color: var(--green); padding: 6px 16px; border-radius: 8px; font-weight: 700; font-size: 1rem; display: inline-block; margin-top: 8px; }

/* Features Deep Dive */
.features { padding: 60px 0; }
.features h2 { text-align: center; font-size: 1.8rem; font-weight: 800; margin-bottom: 40px; }
.feature-compare { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; }
.feature-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 28px; }
.feature-card h3 { font-size: 1.15rem; font-weight: 700; margin-bottom: 16px; }
.feature-item { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.9rem; }
.feature-item:last-child { border-bottom: none; }
.feature-item .label { color: var(--text-dim); }
.feature-item .val { font-weight: 600; }

/* Testimonial / Social Proof */
.social-proof { padding: 60px 0; text-align: center; }
.social-proof h2 { font-size: 1.8rem; font-weight: 800; margin-bottom: 32px; }
.proof-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; max-width: 800px; margin: 0 auto; }
.proof-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 24px; }
.proof-card .stars { color: #F59E0B; font-size: 1.2rem; margin-bottom: 8px; }
.proof-card p { color: var(--text-dim); font-size: 0.9rem; font-style: italic; }
.proof-card .author { margin-top: 12px; font-weight: 600; font-size: 0.85rem; }

/* CTA */
.cta-section { padding: 80px 0; text-align: center; }
.cta-box { background: linear-gradient(135deg, rgba(108,58,237,0.2), rgba(139,92,246,0.1)); border: 1px solid var(--zoo); border-radius: 16px; padding: 60px 40px; max-width: 700px; margin: 0 auto; }
.cta-box h2 { font-size: 2rem; font-weight: 900; margin-bottom: 16px; }
.cta-box p { color: var(--text-dim); margin-bottom: 28px; font-size: 1.05rem; }
.cta-box .price-line { font-size: 1.2rem; margin-bottom: 24px; }
.cta-box .price-line .big { font-size: 2.4rem; font-weight: 900; color: var(--green); }

/* FAQ */
.faq { padding: 60px 0; }
.faq h2 { text-align: center; font-size: 1.8rem; font-weight: 800; margin-bottom: 40px; }
.faq-list { max-width: 700px; margin: 0 auto; }
.faq-item { background: var(--card); border: 1px solid var(--border); border-radius: 10px; margin-bottom: 12px; overflow: hidden; }
.faq-q { padding: 18px 24px; font-weight: 600; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
.faq-q:hover { background: var(--card-hover); }
.faq-a { padding: 0 24px 18px; color: var(--text-dim); font-size: 0.95rem; }

/* Footer */
footer { padding: 40px 0; border-top: 1px solid var(--border); text-align: center; color: var(--text-dim); font-size: 0.85rem; }
footer a { color: var(--zoo-light); }

/* Responsive */
@media (max-width: 640px) {
  .hero h1 { font-size: 1.6rem; }
  .hero-cta { flex-direction: column; align-items: center; }
  .cta-box { padding: 40px 24px; }
  .cta-box h2 { font-size: 1.5rem; }
}
</style>
</head>
